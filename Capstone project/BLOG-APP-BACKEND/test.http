POST http://localhost:4000/user-api/users
Content-Type: application/json

{
  "firstName": "Nenavath",
  "lastName": "Dinesh",
  "email": "nenavathdinesh.08@gmail.com",
  "password": "dinesh@123",
  "profileImageUrl": "https://example.com/avatars/user.png"
}

